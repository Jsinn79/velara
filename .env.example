# Required in production — set these as Vercel project env vars.

# Postgres — attach via Vercel Storage tab (auto-fills this)
DATABASE_URL=

# NextAuth
NEXTAUTH_SECRET=          # generate: openssl rand -base64 32
NEXTAUTH_URL=             # e.g. https://velara.vercel.app
NEXT_PUBLIC_APP_URL=      # same as above

# Stripe (live mode — real charges)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=    # from Stripe Dashboard > Developers > Webhooks after adding the endpoint

# OpenAI (powers the AI feedback analysis)
OPENAI_API_KEY=

# GitHub OAuth App (for YOUR customers connecting their repos)
# Register at https://github.com/settings/developers
# Callback URL: https://<your-domain>/api/integrations/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Vercel Integration (for YOUR customers connecting their projects)
# Register at https://vercel.com/dashboard/integrations/console
# Redirect URL: https://<your-domain>/api/integrations/vercel/callback
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=
